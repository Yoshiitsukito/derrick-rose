NEXT_PUBLIC_SPOTIFY_CLIENT_ID=
NEXT_PUBLIC_SPOTIFY_CLIENT_SECRET=
NEXT_PUBLIC_SPOTIFY_REFRESH_TOKEN=

# --- Google OAuth (заавал бөглөхгүй бол "Google-ээр нэвтрэх" ажиллахгүй) ---
# Google Cloud Console → APIs & Services → Credentials → Create OAuth client ID → Web application
# Authorized redirect URIs: http://localhost:3000/api/auth/google/callback (prod дээр өөрийн домэйн)
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx
# Redirect URI тохиргоонд ашиглагдана — dev: localhost, Vercel: бодит https URL
NEXT_PUBLIC_APP_URL=http://localhost:3000