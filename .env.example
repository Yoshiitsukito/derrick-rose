NEXT_PUBLIC_SPOTIFY_CLIENT_ID=
NEXT_PUBLIC_SPOTIFY_CLIENT_SECRET=
NEXT_PUBLIC_SPOTIFY_REFRESH_TOKEN=

# --- PostgreSQL: нэг мөрийг идэвхжүүлнэ (.env.local-д бодит утга) ---
# Local (Mac) — хэрэглэгч/нууцыг өөрийн Postgres-той тааруулна
# DATABASE_URL=postgresql://postgres:YOUR_LOCAL_PASSWORD@localhost:5432/derrick_rose

# Supabase — шилжих / production: дээрхийг тайлбарлаад доорхыг идэвхжүүлнэ
# Нууцанд @ байвал URL-д %40 гэж encode хийнэ. Нууцыг Supabase → Settings → Database-аас хуулна.
# DATABASE_URL=postgresql://postgres:YOUR_SUPABASE_PASSWORD@db.[project-ref].supabase.co:5432/postgres

DATABASE_URL=

# Сайтын суурь URL (Google OAuth redirect URI-д ашиглагдана)
# Production (Vercel): https://таны-төсөл.vercel.app эсвэл өөрийн домэйн
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Google OAuth (сонголттой) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Resend (холбоо барих)
RESEND_API_KEY=
CONTACT_TO_EMAIL=

# Анхны админ (ensureAdminSeedUser)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# SMTP (тасалбар и-мэйл, сонголттой)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
